#!/bin/sh
set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: sandbox/run <command>

Commands:
  shell           Start the sandbox for the current worktree and enter it
  stop            Stop the current worktree sandbox
  destroy         Tear down the current worktree sandbox and remove its volumes

Each sandbox gets its own project name, infra, and agent container.
Agents (CC/Codex) run inside with writable host credentials mounted in.
EOF
}

resolve_name() {
  worktree_root="$(git -C "$PWD" rev-parse --show-toplevel 2>/dev/null || true)"
  if [ -n "$worktree_root" ]; then
    echo "sandbox-$(basename "$worktree_root")"
    return
  fi

  echo "sandbox-$(basename "$PWD")"
}

ensure_credentials() {
  mkdir -p "$HOME/.claude" "$HOME/.codex" "$HOME/.config/gh"
  touch "$HOME/.claude.json"
}

compose() {
  cd "$REPO_ROOT"
  docker compose \
    -p "$project_name" \
    -f "$REPO_ROOT/docker-compose.yml" \
    -f "$SCRIPT_DIR/docker-compose.yml" \
    "$@"
}

if [ "$#" -eq 0 ]; then
  usage
  exit 1
fi

command="$1"
shift

case "$command" in
  -h|--help|help)
    usage
    exit 0
    ;;
  shell)
    project_name="$(resolve_name)"
    ensure_credentials
    compose up -d --build
    compose exec agent bash
    ;;
  stop)
    project_name="$(resolve_name)"
    compose stop
    ;;
  destroy)
    project_name="$(resolve_name)"
    compose down -v --remove-orphans
    ;;
  *)
    echo "Unknown command: $command" >&2
    usage
    exit 1
    ;;
esac
